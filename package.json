{
  "name": "sms-relay-network",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "infra": "docker-compose up -d redis postgres",
    "easy": "node scripts/easy-dev.mjs",
    "stop": "node scripts/stop-dev.mjs",
    "doctor": "node scripts/doctor.mjs",
    "build": "turbo run build",
    "dev": "pnpm infra && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "latest"
  },
  "packageManager": "pnpm@9.0.0"
}
